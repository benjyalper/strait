# ── AISHub ───────────────────────────────────────────────────────────────────
# Free if you contribute AIS data (run a receiver). Register at:
# https://www.aishub.net/join-us
# Supports bounding-box area search — best option for this app.
AISHUB_USERNAME=your_aishub_username_here

# ── VesselFinder ─────────────────────────────────────────────────────────────
# Credit-based (no free tier). Get a key at:
# https://api.vesselfinder.com
# Note: VesselFinder requires specific MMSI numbers — the app queries a
# pre-defined list of ~40 vessels known to transit the Hormuz corridor.
VESSELFINDER_API_KEY=your_vesselfinder_api_key_here

# ── AISStream.io (TRUE REAL-TIME WebSocket — FREE) ───────────────────────────
# Register free at https://aisstream.io  (GitHub login)
# When set, the browser connects directly via WebSocket for live position
# updates as they happen — no polling. Works alongside or instead of the above.
NEXT_PUBLIC_AISSTREAM_API_KEY=your_aisstream_key_here

# Priority: AISHub is tried first for initial load, then VesselFinder, then
# mock data. AISStream runs in parallel for real-time WebSocket updates.
# You only need to set one of the above for live data.
